{
  "schemaVersion": 2,
  "projectID": "worktime-tracker",
  "displayName": "WorktimeTracker",
  "versionFile": "worktime/VERSION",
  "revisionSource": "git",
  "entries": [
    {
      "id": "app",
      "displayName": "WorktimeTracker App",
      "icon": "clock.arrow.circlepath",
      "type": "managedApplication",
      "workingDirectory": ".",
      "command": {
        "executable": ".venv/bin/python",
        "arguments": ["-m", "worktime.gui"]
      },
      "identity": {
        "type": "pidFile",
        "path": ".runtime/worktime.pid",
        "expectedExecutable": "/opt/homebrew/opt/python@3.13/Frameworks/Python.framework/Versions/Current/Resources/Python.app/Contents/MacOS/Python"
      },
      "graceSeconds": 8
    }
  ]
}
